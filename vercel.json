{
  "version": 2,
  "buildCommand": "npm install && cd client && npm install && npm run build",
  "outputDirectory": "client/build",
  "installCommand": "npm install",
  "functions": {
    "api/auth.js":     { "memory": 256, "maxDuration": 10 },
    "api/apuestas.js": { "memory": 256, "maxDuration": 10 },
    "api/admin.js":    { "memory": 256, "maxDuration": 10 },
    "api/recargas.js": { "memory": 256, "maxDuration": 10 },
    "api/health.js":   { "memory": 128, "maxDuration": 5  }
  },
  "routes": [
    { "src": "/api/auth/(.*)",      "dest": "/api/auth.js"     },
    { "src": "/api/apuestas/(.*)",  "dest": "/api/apuestas.js" },
    { "src": "/api/apuestas",       "dest": "/api/apuestas.js" },
    { "src": "/api/admin/(.*)",     "dest": "/api/admin.js"    },
    { "src": "/api/admin",          "dest": "/api/admin.js"    },
    { "src": "/api/recargas/(.*)",  "dest": "/api/recargas.js" },
    { "src": "/api/recargas",       "dest": "/api/recargas.js" },
    { "src": "/api/health",         "dest": "/api/health.js"   },
    { "handle": "filesystem" },
    { "src": "/(.*)",               "dest": "/index.html"       }
  ]
}
